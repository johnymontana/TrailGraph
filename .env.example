# ─── NPS Data API ──────────────────────────────────────────────
NPS_API_KEY=                      # sent as X-Api-Key header

# ─── Sync (Vercel Cron) ────────────────────────────────────────
CRON_SECRET=                      # Vercel Cron Authorization bearer. Cron routes fail CLOSED when this
                                  # is unset (sync/digests/memory-reconcile 401), so set it in EVERY
                                  # environment — production AND preview — or the scheduled jobs 401.

# ─── Neo4j (single canonical store: domain + context + app data) ─
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=
NEO4J_DATABASE=neo4j

# ─── NAMS (memory) — hosted, pointed at our external Neo4j (ADR-001)
# Read from env, never hard-code; rotate within 90 days.
NAMS_BASE_URL=                    # leave BLANK to use the SDK's built-in hosted endpoint; set only to override (REST base; /v1 appended automatically)
NAMS_API_KEY=                     # nams_… Bearer token
NAMS_WORKSPACE_ID=                # X-Workspace-Id (omit if token is workspace-scoped)

# ─── Auth (Better Auth, passwordless magic link) ────────────────
BETTER_AUTH_SECRET=               # openssl rand -base64 32
BETTER_AUTH_URL=http://localhost:3000
RESEND_API_KEY=                   # transactional email for magic links
EMAIL_FROM="TrailGraph <ranger@trailgraph.app>"

# ─── Routing (RoutingGateway → OpenRouteService) ────────────────
ORS_API_KEY=                      # openrouteservice.org free tier
ORS_BASE_URL=https://api.openrouteservice.org

# ─── Maps ───────────────────────────────────────────────────────
NEXT_PUBLIC_MAP_TILES_URL=/basemap/us.pmtiles   # self-hosted Protomaps `.pmtiles` (run `pnpm build:basemap`) OR a MapLibre `style.json`. Missing file → demo tiles. See README "Basemap".
# Prod: the PUBLIC Blob CDN URL — https://<store>.public.blob.vercel-storage.com/<path>.pmtiles (no query string).
# NEVER use a *.private.blob… or signed `?vercel-blob-delegation=…` URL: it ignores HTTP range requests
# (the whole .pmtiles downloads to every client) and the signed token expires ~12h after each deploy.

# ─── Models / embeddings (via Vercel AI Gateway + OIDC) ─────────
# No provider keys in code on Vercel. For local dev set a gateway key if needed.
AI_GATEWAY_API_KEY=
EMBEDDING_MODEL=openai/text-embedding-3-small   # 1536-dim, config-swappable (ADR-012)
AGENT_MODEL=anthropic/claude-sonnet-4.6         # one model for v1 (ADR-014); DOT variant — Eve has no metadata for the dash form
