{
  "name": "trailgraph",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "next dev --webpack",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "theme:typegen": "chakra typegen ./theme/index.ts",
    "postinstall": "node -e \"const { existsSync } = require('node:fs'); const { join } = require('node:path'); const cli = join(process.cwd(), 'node_modules', '@chakra-ui', 'cli', 'bin', 'index.js'); if (existsSync(cli)) require('node:child_process').execFileSync(process.execPath, [cli, 'typegen', './theme/index.ts'], { stdio: 'inherit' });\"",
    "db:migrate": "tsx db/migrate.ts",
    "db:verify": "tsx db/verify.ts",
    "db:fix-encoded-names": "tsx scripts/fix-encoded-names.ts",
    "nams:spike": "tsx scripts/spike-nams-external-neo4j.ts",
    "ontology:setup": "tsx scripts/setup-ontology.ts",
    "seed:test": "tsx scripts/seed-test-data.ts",
    "cleanup:orphan-stops": "tsx scripts/cleanup-orphan-stops.ts",
    "analytics:rebuild": "tsx scripts/rebuild-analytics.ts",
    "sync:reset": "tsx scripts/reset-sync-checkpoint.ts",
    "build:basemap": "tsx scripts/build-basemap.ts",
    "build:glyphs": "tsx scripts/build-glyphs.ts",
    "basemap:upload": "tsx scripts/upload-basemap.ts",
    "datasources:sync": "tsx scripts/sync-datasources.ts",
    "trails:sync": "tsx scripts/sync-trails.ts",
    "visitation:build": "tsx scripts/build-visitation-dataset.ts",
    "agent:dev": "eve dev",
    "agent:info": "eve info",
    "agent:link": "eve link",
    "agent:eval": "eve eval",
    "test": "vitest run",
    "test:unit": "vitest run --project unit",
    "test:integration": "vitest run --project integration",
    "test:watch": "vitest",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@chakra-ui/charts": "^3.36.0",
    "@chakra-ui/react": "^3.36.0",
    "@emotion/cache": "^11.14.0",
    "@emotion/react": "^11.14.0",
    "@neo4j-labs/agent-memory": "0.4.0",
    "@neo4j-nvl/base": "^1.2.0",
    "@neo4j-nvl/react": "^1.2.0",
    "@vercel/analytics": "^2.0.1",
    "@vercel/blob": "^2.4.1",
    "ai": "7.0.0-beta.178",
    "astronomy-engine": "^2.1.19",
    "better-auth": "^1.6.20",
    "eve": "0.12.0",
    "jszip": "^3.10.1",
    "maplibre-gl": "^5.24.0",
    "motion": "^12.41.0",
    "neo4j-driver": "^6.1.0",
    "next": "^16.2.9",
    "next-themes": "^0.4.6",
    "pmtiles": "^4.4.1",
    "protomaps-themes-base": "^4.5.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-icons": "^5.5.0",
    "react-markdown": "^10.1.0",
    "recharts": "^3.8.1",
    "remark-gfm": "^4.0.1",
    "resend": "^6.14.0",
    "satellite.js": "^7.0.1",
    "workflow": "^4.5.0",
    "zod": "^4.4.0"
  },
  "devDependencies": {
    "@chakra-ui/cli": "^3.36.0",
    "@playwright/test": "^1.61.0",
    "@types/geojson": "^7946.0.16",
    "@types/node": "^22.10.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "microsandbox": "^0.5.7",
    "tsx": "^4.22.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.9"
  }
}
